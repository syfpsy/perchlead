# Perchlead — environment template.
# Copy to .env.local for dev and configure on Vercel for production.
# All secrets stay local; never commit real keys.

# ---- App ----
NEXT_PUBLIC_APP_NAME=Perchlead
NEXT_PUBLIC_DATA_MODE=local   # local | neon

# ---- Neon Postgres (when ready) ----
# Pooled connection — for runtime queries from Vercel functions.
DATABASE_URL=
# Unpooled / direct connection — for migrations and long-lived sessions.
DATABASE_URL_UNPOOLED=

# ---- Auth (when wiring real auth on top of Neon) ----
# Pick one provider; these are placeholders. See db/README.md.
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ---- HeroUI Pro ----
# Pro registry auth lives in your machine-level ~/.npmrc, not in this repo.
# These vars are only consumed by helper scripts that materialize an .npmrc
# on CI; they are NOT read by the app at runtime.
HEROUI_PRO_KEY=
HEROUI_LICENSE_KEY=

# ---- Future provider hooks (mocked in MVP) ----
HUNTER_API_KEY=
APOLLO_API_KEY=
PEOPLE_DATA_LABS_API_KEY=
GOOGLE_PLACES_API_KEY=
